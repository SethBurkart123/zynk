{
  "name": "zynk-kitchen-sink-harness",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bun run index.ts",
    "test:rust": "bun run index.ts --mode=rust",
    "test:cross": "bun run index.ts --mode=cross",
    "test:all": "bun run index.ts --mode=all",
    "test:parity": "bun run index.ts --mode=parity",
    "test:errors": "bun run index.ts --mode=errors",
    "test:debug-flag": "bun run index.ts --mode=debug-flag",
    "test:case-normalization": "bun run index.ts --mode=case-normalization",
    "test:effect": "bun run effect.ts",
    "typecheck": "bun x tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "effect": "^3.21.2"
  }
}
